# 页面标题
VUE_APP_TITLE = 智慧农业监测系统

# 开发环境配置
ENV = 'development'

# 开发环境
VUE_APP_BASE_API = '/dev-api'

# 路由懒加载
VUE_CLI_BABEL_TRANSPILE_MODULES = true

# ---------- 局域网访问（场景 A，可选） ----------
# 其他设备通过 http://<本机IP> 访问时，若热更新异常可取消下行注释并改为本机 IP：
# VUE_APP_PUBLIC_HOST = 192.168.1.100
# 后端不在本机 8080 时可改代理目标：
# VUE_APP_BACKEND_URL = http://127.0.0.1:8080
